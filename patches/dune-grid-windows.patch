 #include <dune/grid/common/gridfactory.hh>
 
+// MSVC lacks the POSIX large-file functions ftello/fseeko; map them to the
+// Microsoft 64-bit equivalents so the Gmsh reader compiles natively. (off_t is
+// already provided by MSVC's <sys/types.h>, so it is not redefined here.)
+#if defined(_MSC_VER)
+#include <cstdio>
+#define ftello _ftelli64
+#define fseeko _fseeki64
+#endif
+
 namespace Dune
